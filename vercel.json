{
  "version": 2,
  "rewrites": [
    {
      "source": "/project-details.php",
      "destination": "/api/index.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!assets/|.*\\..*$).*)",
      "destination": "/index.html"
    }
  ]
}
