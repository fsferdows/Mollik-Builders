{
  "version": 2,
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/project-details.php",
      "destination": "/api/index.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!assets/|uploads/|.*\\..*$).*)",
      "destination": "/index.html"
    }
  ]
}
